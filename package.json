{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Decision memory for AI-built software.",
  "engines": {
    "node": ">=22.0.0"
  },
  "allowScripts": {
    "esbuild": true,
    "protobufjs": true,
    "sharp": true,
    "unrs-resolver": true
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run typecheck && npm run test",
    "env:check": "node scripts/check-env.mjs"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "inngest": "^4.13.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "openai": "^6.47.0",
    "pdfkit": "^0.19.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swr": "^2.3.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
